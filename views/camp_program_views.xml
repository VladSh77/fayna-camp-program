<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Tree View -->
        <record id="camp_program_tree" model="ir.ui.view">
            <field name="name">camp.program.tree</field>
            <field name="model">camp.program</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="event_id" />
                    <field name="date" />
                    <field name="name" />
                    <field name="start_time" />
                    <field name="end_time" />
                    <field name="plan_variant" />
                    <field name="state" />
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record id="camp_program_form" model="ir.ui.view">
            <field name="name">camp.program.form</field>
            <field name="model">camp.program</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="event_id" />
                                <field name="product_tmpl_id" />
                                <field name="schedule_entry_id" />
                            </group>
                            <group>
                                <field name="date" />
                                <field name="start_time" />
                                <field name="end_time" />
                            </group>
                        </group>

                        <group>
                            <group>
                                <field name="name" />
                                <field name="sequence" />
                                <field name="plan_variant" />
                                <field name="state" />
                            </group>
                            <group>
                                <field name="participant_count" />
                                <field name="staff_ids" widget="many2many_tags" />
                            </group>
                        </group>

                        <notebook>
                            <page string="Description">
                                <field name="description" />
                            </page>
                            <page string="Incidents & Deviations">
                                <field name="incidents" />
                            </page>
                            <page string="Photos">
                                <field name="photo_attachment_ids" widget="many2many_tags" />
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="camp_program_search" model="ir.ui.view">
            <field name="name">camp.program.search</field>
            <field name="model">camp.program</field>
            <field name="arch" type="xml">
                <search>
                    <field name="event_id" />
                    <field name="name" />
                    <field name="date" />
                    <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]" />
                    <filter name="filter_scheduled" string="Scheduled" domain="[('state', '=', 'scheduled')]" />
                    <filter name="filter_ongoing" string="Ongoing" domain="[('state', '=', 'ongoing')]" />
                    <filter name="filter_completed" string="Completed" domain="[('state', '=', 'completed')]" />
                    <filter name="filter_cancelled" string="Cancelled" domain="[('state', '=', 'cancelled')]" />
                    <filter name="filter_plan_a" string="Plan A (sunny)" domain="[('plan_variant', '=', 'a')]" />
                    <filter name="filter_plan_b" string="Plan B (rainy)" domain="[('plan_variant', '=', 'b')]" />
                    <group expand="0" string="Group By">
                        <filter name="group_by_event" string="Event" context="{'group_by': 'event_id'}" />
                        <filter name="group_by_date" string="Date" context="{'group_by': 'date'}" />
                        <filter name="group_by_state" string="State" context="{'group_by': 'state'}" />
                        <filter name="group_by_plan_variant" string="Plan Variant" context="{'group_by': 'plan_variant'}" />
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="camp_program_action" model="ir.actions.act_window">
            <field name="name">Camp Programs</field>
            <field name="res_model">camp.program</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{}</field>
        </record>

        <!-- Menu -->
        <menuitem
            id="camp_program_menu"
            name="Programs"
            action="camp_program_action"
            parent="camp_program_menu_root"
            sequence="10"
        />
    </data>
</odoo>
